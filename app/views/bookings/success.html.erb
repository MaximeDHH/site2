<section class="result-page">
  <div class="result-blob"></div>
  <div class="container result-inner">
    <div class="result-icon success-icon">
      <i class="fa-solid fa-check"></i>
    </div>
    <h1>Réservation confirmée !</h1>
    <% if @booking %>
      <p class="result-sub">
        Merci <strong><%= @booking.name %></strong> — votre rendez-vous pour
        <strong><%= @booking.service %></strong> le
        <strong><%= @booking.date.strftime('%d/%m/%Y') %></strong> à
        <strong><%= @booking.time_slot %></strong> est bien enregistré.
      </p>
      <p class="result-sub">Un récapitulatif a été envoyé à <strong><%= @booking.email %></strong>.</p>
    <% end %>
    <%= link_to root_path, class: 'btn-outline' do %>
      Retour à l'accueil
    <% end %>
  </div>
</section>
