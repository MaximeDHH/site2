<% if @shop_closed %>
  <div class="shop-closed-banner">
    <i class="fa-solid fa-circle-exclamation"></i>
    <% if @shop_closure[:from] == @shop_closure[:to] %>
      Le salon est fermé le <%= I18n.l(@shop_closure[:from], format: :long) %>. Nous vous accueillons dès le lendemain.
    <% else %>
      Le salon est fermé du <%= I18n.l(@shop_closure[:from], format: :long) %> au <%= I18n.l(@shop_closure[:to], format: :long) %>. À très bientôt !
    <% end %>
  </div>
<% end %>

<!-- HERO SPLIT -->
<section class="hero-split">
  <div class="hero-left">
    <p class="hero-tag">Salon d'onglerie · Paris
    </p>
    <h1>Des mains sublimes,<br>pour vos plus<br>beaux moments.</h1>
    <p class="hero-desc">Chez Royal Nail, des professionnelles passionnées subliment vos mains dans un cadre chaleureux et raffiné.</p>
    <div class="hero-actions">
      <%= link_to 'Réserver', new_booking_path, class: 'btn-yellow' %>
      <a href="#services" class="btn-outline-dark">Voir les prestations</a>
    </div>
  </div>
  <div class="hero-right">
    <%= image_tag 'pexels-cottonbro-5871914.jpg', alt: 'Royal Nail', class: 'hero-img' %>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
