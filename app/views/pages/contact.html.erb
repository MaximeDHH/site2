<%= render 'shared/hero',
  hero_class: 'contact-hero',
  hero_title: 'Prenez rendez-vous',
  hero_description: 'Nous sommes à votre écoute pour toute question ou réservation.' %>

<section class="contact-section">
  <div class="container">
    <div class="contact-grid">

      <div class="contact-info">
        <p class="section-eyebrow">Nous trouver</p>
        <h2>Informations pratiques</h2>
        <div class="gold-bar"></div>

        <div class="info-list">
          <div class="info-item">
            <i class="fa-solid fa-location-dot"></i>
            <div>
              <strong>Adresse</strong>
              <span>64 rue Brancion, 75015 Paris</span>
            </div>
          </div>
          <div class="info-item">
            <i class="fa-solid fa-phone"></i>
            <div>
              <strong>Téléphone</strong>
              <span><a href="tel:+33627358188">06 27 35 81 88</a></span>
            </div>
          </div>
          <div class="info-item">
            <i class="fa-solid fa-clock"></i>
            <div>
              <strong>Horaires</strong>
              <span>Lundi — Dimanche : 10h – 20h</span>
            </div>
          </div>
          <div class="info-item">
            <i class="fa-solid fa-envelope"></i>
            <div>
              <strong>Email</strong>
              <span><a href="mailto:contact@royalnail.fr">contact@royalnail.fr</a></span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-map">
        <iframe
          class="google-map"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src="https://maps.google.com/maps?q=64%20rue%20Brancion%2C%2075015%20Paris&t=&z=16&ie=UTF8&iwloc=&output=embed">
        </iframe>

        <div class="metro-badge">
          <p class="metro-badge-title">Accès en transports</p>
          <div class="metro-tags">
            <span class="metro-tag metro-tag--13">13 · Porte de Vanves</span>
            <span class="metro-tag metro-tag--12">12 · Convention</span>
            <span class="metro-tag metro-tag--bus">Bus 89</span>
            <span class="metro-tag metro-tag--bus">Bus 95</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
