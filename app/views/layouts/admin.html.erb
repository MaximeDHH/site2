<!DOCTYPE html>
<html>
  <head>
    <link href="https://fonts.googleapis.com/css2?family=Rufina:wght@400;700&family=Lato:wght@300;400;700&family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" %>
    <title>Royal Nail — Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "admin/admin", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="admin-body">
    <aside class="admin-sidebar">
      <div class="admin-brand">
        <div class="admin-logo-badge">R</div>
        <div>
          <span class="admin-logo-name">Royal Nail</span>
          <span class="admin-logo-sub">Administration</span>
        </div>
      </div>
      <nav class="admin-nav">
        <%= link_to admin_root_path, class: "admin-nav-item #{'active' if controller_name == 'bookings'}" do %>
          <i class="fa-solid fa-calendar-check"></i> Réservations
        <% end %>
        <%= link_to admin_stats_path, class: "admin-nav-item #{'active' if controller_name == 'stats'}" do %>
          <i class="fa-solid fa-chart-bar"></i> Statistiques
        <% end %>
      </nav>
      <div class="admin-sidebar-footer">
        <% shop_closed = Admin::ShopController.closure&.then { |c| Date.today.between?(c[:from], c[:to]) } %>
        <%= link_to admin_shop_path,
              class: "admin-shop-toggle #{'admin-shop-toggle--closed' if shop_closed}" do %>
          <i class="fa-solid <%= shop_closed ? 'fa-door-open' : 'fa-door-closed' %>"></i>
          <%= shop_closed ? 'Salon fermé' : 'Fermeture salon' %>
        <% end %>
        <a href="/" class="admin-nav-item">
          <i class="fa-solid fa-arrow-left"></i> Voir le site
        </a>
      </div>
    </aside>

    <main class="admin-main">
      <% if notice.present? %>
        <div class="admin-flash admin-flash--notice"><%= notice %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
